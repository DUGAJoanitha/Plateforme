{
  "info": {
    "_postman_id": "plateforme-backend-api",
    "name": "Plateforme Backend API",
    "description": "Collection complète des endpoints de la Plateforme. Utilisez l'environnement `Local` pour les tests en développement.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "access_token", "value": "" },
    { "key": "project_id", "value": "1" },
    { "key": "org_id", "value": "1" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.test('Registration returns token', () => pm.expect(json.access_token).to.not.be.empty);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"org_id\": {{org_id}}\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.test('Login returns token', () => pm.expect(json.access_token).to.not.be.empty);",
                  "  pm.test('Token type is Bearer', () => pm.expect(json.token_type).to.eql('Bearer'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get Profile (me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has data key', () => pm.expect(pm.response.json()).to.have.property('data'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('access_token', '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "📁 Projects",
      "item": [
        {
          "name": "List Projects",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has data array', () => pm.expect(pm.response.json()).to.have.property('data'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/projects?per_page=10",
              "host": ["{{base_url}}"],
              "path": ["projects"],
              "query": [{ "key": "per_page", "value": "10" }, { "key": "status", "value": "active", "disabled": true }]
            }
          }
        },
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('project_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Projet Eau Potable 2025\",\n  \"description\": \"Accès à l'eau potable pour 5000 personnes\",\n  \"budget_total\": 150000,\n  \"start_date\": \"2025-07-01\",\n  \"end_date\": \"2026-06-30\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects", "host": ["{{base_url}}"], "path": ["projects"] }
          }
        },
        {
          "name": "Get Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has data key', () => pm.expect(pm.response.json()).to.have.property('data'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}"] }
          }
        },
        {
          "name": "Update Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Projet Eau Potable 2025 (Mis à jour)\",\n  \"status\": \"active\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}"] }
          }
        },
        {
          "name": "Project Dashboard",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has activities section', () => pm.expect(json.data).to.have.property('activities'));",
                  "pm.test('Has kpis section', () => pm.expect(json.data).to.have.property('kpis'));",
                  "pm.test('Has budget section', () => pm.expect(json.data).to.have.property('budget'));",
                  "pm.test('Has risks section', () => pm.expect(json.data).to.have.property('risks'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/dashboard", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "dashboard"] }
          }
        },
        {
          "name": "Delete Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}"] }
          }
        }
      ]
    },
    {
      "name": "📊 KPIs",
      "item": [
        {
          "name": "List KPIs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/kpis", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "kpis"] }
          }
        },
        {
          "name": "Create KPI",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Taux d'accès à l'eau\",\n  \"target_value\": 5000,\n  \"current_value\": 0,\n  \"unit\": \"personnes\",\n  \"frequency\": \"monthly\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/kpis", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "kpis"] }
          }
        },
        {
          "name": "Add KPI Measure",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": 1250,\n  \"notes\": \"Mesure du mois de juillet\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/kpis/1/measures", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "kpis", "1", "measures"] }
          }
        }
      ]
    },
    {
      "name": "💰 Finance",
      "item": [
        {
          "name": "Budget Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/finance/summary", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "finance", "summary"] }
          }
        },
        {
          "name": "List Budget Lines",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/finance/budgets", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "finance", "budgets"] }
          }
        },
        {
          "name": "Create Budget Line",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Personnel\",\n  \"description\": \"Salaires équipe terrain\",\n  \"allocated\": 50000\n}"
            },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/finance/budgets", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "finance", "budgets"] }
          }
        },
        {
          "name": "Submit Expense",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1500,\n  \"description\": \"Achat de matériel de forage\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/finance/budgets/1/expenses", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "finance", "budgets", "1", "expenses"] }
          }
        }
      ]
    },
    {
      "name": "🤖 IA & Rapports",
      "item": [
        {
          "name": "Analyser Projet (IA)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/ai/analyze", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "ai", "analyze"] }
          }
        },
        {
          "name": "Prédire Risques (IA)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/ai/predict-risks", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "ai", "predict-risks"] }
          }
        },
        {
          "name": "Générer Rapport",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"monthly\",\n  \"format\": \"pdf\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects/{{project_id}}/reports/generate", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}", "reports", "generate"] }
          }
        }
      ]
    },
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API is healthy', () => pm.response.to.have.status(200));",
                  "pm.test('Status is healthy', () => pm.expect(pm.response.json().status).to.eql('healthy'));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/../health", "host": ["{{base_url}}"], "path": ["..", "health"] }
          }
        }
      ]
    }
  ]
}
