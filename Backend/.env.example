APP_NAME="PISE-PP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ========== DATABASE ==========
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Alternative: PostgreSQL (recommended for production)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=pise_pp
# DB_USERNAME=postgres
# DB_PASSWORD=secret

BCRYPT_ROUNDS=12

# ========== CACHE & SESSION ==========
CACHE_DRIVER=redis
CACHE_PREFIX=pise_pp_cache_
SESSION_DRIVER=cookie
SESSION_LIFETIME=525600

# ========== QUEUE ==========
QUEUE_CONNECTION=redis

# ========== REDIS ==========
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ========== MAIL ==========
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@pise-pp.local"
MAIL_FROM_NAME="${APP_NAME}"

# ========== STORAGE ==========
FILESYSTEM_DISK=public
BROADCAST_CONNECTION=log

# ========== 2FA CONFIGURATION ==========
TOTP_WINDOW=1
TWO_FACTOR_SESSION_TIMEOUT=5

# ========== SECURITY ==========
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
APP_SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT=5

# ========== SANCTUM / JWT ==========
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000
SANCTUM_GUARD=sanctum

# ========== API SETTINGS ==========
API_VERSION=v1
API_PAGINATION_LIMIT=15

# ========== EXTERNAL SERVICES (Optional) ==========
# OpenAI API for AI recommendations
# OPENAI_API_KEY=sk-...

# Google Gemini API (alternative to OpenAI)
# GOOGLE_GEMINI_API_KEY=AIzaSy...

# AWS S3 for file storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Twilio for SMS 2FA
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_PHONE=+1234567890

# Firebase Cloud Messaging for push notifications
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=

# ========== AUDIT & LOGGING ==========
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# ========== FEATURE FLAGS ==========
FEATURE_AI_ENABLED=false
FEATURE_MOBILE_OFFLINE=true
FEATURE_ADVANCED_REPORTING=false

# ========== DEVELOPMENT ==========
DEBUGBAR_ENABLED=true
VITE_APP_NAME="${APP_NAME}"
